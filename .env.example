# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Eski panel: anon public key | Yeni: publishable key — ikisinden biri yeterli
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Yalnız sunucu (Vercel’de Secret). İstemciye / NEXT_PUBLIC_ ile vermeyin. Öneri: article_submissions vb. güvenli insert.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Moderasyon (/admin/moderation): Supabase Auth’taki kullanıcı e-postaları, virgülle
MASTER_EMAILS=you@example.com

# Site URL — yerelde localhost; Vercel’de önerilen:
# - Özel alan: https://www.ornek.com (Production + Preview’de aynı canonical istiyorsanız)
# - Sadece *.vercel.app: bu satırı Vercel’de boş bırakın; VERCEL_URL otomatik kullanılır
NEXT_PUBLIC_SITE_URL=http://localhost:3000
